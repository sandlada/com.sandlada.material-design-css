    <div class="footer-container">
        <section class="follow-us-part">
            <a tabindex="0" href={Consts.social.twitter.link} target="_blank" aria-label="Open the Twitter(X) link of Sandlada team in a new tab">
                <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" width="40" height="40" viewBox="0 0 260 260" xml:space="preserve">
                    <path xmlns="http://www.w3.org/2000/svg" d="M130,2C59.31,2,2,59.31,2,130s57.31,128,128,128s128-57.31,128-128S200.69,2,130,2z M194.08,97.09l0.11,4.28  c0,50.62-33.26,94.13-94.12,94.13c-18.69,0-36.07-5.48-50.71-14.89c2.59,0.3,5.22,0.46,7.89,0.46c15.5,0,29.77-5.27,41.08-14.14  c-14.47-0.26-26.43-9.08-30.64-22.23c5.11,0.82,11.26,0.12,14.69-1.29c-7.56-1.53-14.19-5.63-18.94-11.36  c-4.74-5.72-7.59-13.07-7.59-21.08c4.46,2.48,9.56,3.55,14.98,3.74c-8.87-5.93-14.71-16.06-14.71-27.54  c0-6.06,1.62-11.75,4.47-16.62c16.32,20.01,40.7,33.18,68.19,34.56c-0.57-2.42-0.86-4.95-0.86-7.54c0-18.26,14.82-33.07,33.09-33.07  c9.52,0,17.54,3.99,23.11,9.42c6.25-0.21,14.88-3.21,22.05-7c-2.47,7.71-7.71,14.2-14.54,18.29c6.69-0.26,12.43-1.65,18.36-4.28  C205.57,87.56,200.58,92.46,194.08,97.09z"></path>
                </svg>
                <md-focus-ring></md-focus-ring>
            </a>

            <a tabindex="0" href={Consts.social.github.link} target="_blank" aria-label="Open the Github link of the MaterialDesignCSS repository in a new tab">
                <svg aria-hidden="true" width="40" height="40" viewBox="0 0 24 24">
                    <path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm2.218 18.616c-.354.069-.468-.149-.468-.336v-1.921c0-.653-.229-1.079-.481-1.296 1.56-.173 3.198-.765 3.198-3.454 0-.765-.273-1.389-.721-1.879.072-.177.312-.889-.069-1.853 0 0-.587-.188-1.923.717-.561-.154-1.159-.231-1.754-.234-.595.003-1.193.08-1.753.235-1.337-.905-1.925-.717-1.925-.717-.379.964-.14 1.676-.067 1.852-.448.49-.722 1.114-.722 1.879 0 2.682 1.634 3.282 3.189 3.459-.2.175-.381.483-.444.936-.4.179-1.413.488-2.037-.582 0 0-.37-.672-1.073-.722 0 0-.683-.009-.048.426 0 0 .46.215.777 1.024 0 0 .405 1.25 2.353.826v1.303c0 .185-.113.402-.462.337-2.782-.925-4.788-3.549-4.788-6.641 0-3.867 3.135-7 7-7s7 3.133 7 7c0 3.091-2.003 5.715-4.782 6.641z"></path>
                </svg>
                <md-focus-ring></md-focus-ring>
            </a>

            <a tabindex="0" href={Consts.social.npm.link} target="_blank" aria-label="Open the NPM link of the MaterialDesignCSS repository in a new tab">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 1024 1024">
                    <circle cx="512" cy="512" r="512"></circle>
                    <path d="M407.26 599.29h69.83v-34.92h69.83V424.71H407.26zm69.83-139.66H512v69.83h-34.91zm97.76-34.91v139.65h69.83V459.63h34.91v104.74h34.91V459.63h34.91v104.74h34.91V424.71zM239.67 564.37h69.83V459.63h34.91v104.74h34.91V424.71H239.67z" fill="var(--md-sys-color-surface)">
                    </path>
                </svg>
                <md-focus-ring></md-focus-ring>
            </a>
        </section>

        <section class="develop-information">
            <a tabindex="0" class="link" target="_blank" href={Consts.repo.MaterialDesignCSS.githubLink} aria-label="Open the MaterialDesignCSS Github link in a new tab">
                <span class="body-medium">{Consts.repo.MaterialDesignCSS.formalName}</span>
                <md-focus-ring></md-focus-ring>
            </a>
            <a tabindex="0" class="link" target="_blank" href={Consts.repo.MaterialDesignCSS.licenseLink} aria-label="Open the MIT License link of MaterialDesignCSS on Github in a new tab">
                <span class="body-medium">{Consts.repo.MaterialDesignCSS.licenseName} License</span>
                <md-focus-ring></md-focus-ring>
            </a>
            <a tabindex="0" class="link" target="_blank" href={Consts.member.kaiOrion.offcialWebLink} aria-label="Open Kai Orion's webpage link in a new tab">
                <span class="body-medium">{Consts.member.kaiOrion.formalName}</span>
                <md-focus-ring></md-focus-ring>
            </a>
        </section>
    </div>
</footer>

<style>
    .footer-container {
        min-height: unset;
        box-sizing: border-box;
        display: block;
        margin-left: auto;
        margin-right: auto;
        padding-block-start: 24px;
        padding-block-start: 24px;
        overflow: auto;
        position: relative;

        @media (width >=640px) {
            max-width: 640px;
        }

        @media (width >=768px) {
            max-width: 768px;
        }

        @media (width >=1024px) {
            max-width: 1024px;
        }

        @media (width >=1280px) {
            max-width: 1280px;
        }
    }

    .website-footer.top-level {
        box-sizing: border-box;
        background-color: var(--md-sys-color-surface);
        z-index: 0;
        position: relative;
        padding-block-start: 48px;

        & .develop-information {
            display: flex;
            padding: 24px 0px;
            gap: 16px;
            color: var(--md-sys-color-on-surface-variant);

            & .link {
                all: unset;
                cursor: pointer;
                position: relative;
            }
            & .link:hover {
                text-decoration-line: underline;
            }
        }

        & .follow-us-part {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 24px 0px;

            & > a {
                all: unset;
                cursor: pointer;
                position: relative;
                fill: currentColor;
                height: 40px;
                width: 40px;

                & > svg {
                    fill: currentColor;
                    fill: var(--md-sys-color-on-surface);
                }
            }
        }
    }

    .follow-us-part,
    .develop-information {
        md-focus-ring {
            border-radius: 999px;
        }
    }
</style>
